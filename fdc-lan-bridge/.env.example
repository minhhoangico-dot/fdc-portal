# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HIS PostgreSQL
HIS_DB_HOST=localhost
HIS_DB_PORT=5432
HIS_DB_NAME=his_db
HIS_DB_USER=his_user
HIS_DB_PASSWORD=his_password

# MISA SQL Server
MISA_DB_SERVER=localhost
MISA_DB_PORT=1433
MISA_DB_NAME=misa_db
MISA_DB_USER=misa_user
MISA_DB_PASSWORD=misa_password

# Hikvision Time Attendance
HIKVISION_HOST=192.168.1.100
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=your-password

# Bridge HTTP server
PORT=3333

