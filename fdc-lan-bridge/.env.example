# Self-hosted Supabase
SUPABASE_URL=http://192.168.1.9:8000
SUPABASE_SERVICE_ROLE_KEY=your-self-hosted-service-role-key

# HIS PostgreSQL
HIS_DB_HOST=localhost
HIS_DB_PORT=5432
HIS_DB_NAME=his_db
HIS_DB_USER=his_user
HIS_DB_PASSWORD=his_password

# MISA SQL Server
MISA_DB_SERVER=localhost
MISA_DB_PORT=1433
MISA_DB_NAME=misa_db
MISA_DB_USER=misa_user
MISA_DB_PASSWORD=misa_password

# Hikvision Time Attendance
HIKVISION_HOST=192.168.1.100
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=your-password

# Bridge HTTP server
PORT=3333

# TV access policy
# JSON arrays. Network allowlist is checked first. If no network matches,
# frontend falls back to browser geolocation using the configured sites.
TV_ALLOWED_NETWORKS=[{"key":"phong_kham","label":"Phong kham","cidrs":["203.0.113.0/24"]},{"key":"chi_nhanh","label":"Chi nhanh","cidrs":["198.51.100.0/24"]}]
TV_ALLOWED_SITES=[{"key":"phong_kham","label":"Phong kham","latitude":10.762622,"longitude":106.660172,"radiusMeters":200},{"key":"chi_nhanh","label":"Chi nhanh","latitude":10.776889,"longitude":106.700806,"radiusMeters":200}]

